    ISBN, TITLE, AUTHOR, EDITION, PUBLISHER, DATE,
    DEWEY, LCCN, CATALOGNUMBER, PAGES, SOURCE
)
SELECT
    b.ISBN, b.TITLE, b.AUTHOR, b.EDITION, b.PUBLISHER, b.DATE,
    b.DEWEY, b.LCCN, b.CATALOGNUMBER, CAST(b.PAGES AS VARCHAR), b.SOURCE
FROM BOOKS_WESLEY b
WHERE b.ISBN NOT IN (SELECT ISBN FROM WESLEY_LIBRARY WHERE ISBN IS NOT NULL);


